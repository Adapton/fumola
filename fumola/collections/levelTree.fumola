  };

  public module Viz {

  public type Geom2D = {
    height : Nat;
    width : Nat;
    widthLeft : Nat;
    widthRight : Nat;
  };

  public type SceneObject = {
    #orb : Orb;
    #box : Box;
    #action : Action;
    #pointer : Pointer;
  };

  public let zero = {x=0;y=0;z=0};
  public type Vec3 = { x : Float; y : Float; z : Float };

  public func sceneIntoJSONText( objects : [SceneObject] ) : Text {
    var objectsText = "";
    var isFirstObject = true;
    for (o in objects.vals()) {
      if (isFirstObject) {
        isFirstObject := false;
      } else {
        objectsText #= ",\n";
      };
      switch o {
        case (#box(fields)) {
          objectsText #= 
              "{ \"type\": \"box\""#
              ", \"position\": "#(debug_show [fields.position.x, fields.position.y, fields.position.z])#
              ", \"label\": "#(debug_show fields.label_)#
              ", \"textLines\": "#(debug_show fields.textFields)#
              ", \"pointerFields\": "#(debug_show fields.pointerFields)#
              "}"
        };
        case (#pointer(fields)) {
          objectsText #= 
             "{ \"type\": \"pointer\", \"from\": " # (debug_show fields.from) # 
                                 ", \"to\": " # (debug_show fields.to) # 
              "}"
        };
      }
    };
    "{ \"objects\" : [\n" # objectsText # "\n] }"
  };

  public func writeSceneFile<X>(symbol : Symbol, tree : Pointer<SeqTree<X>>) {
    prim "writeFile" (symbol, sceneIntoJSONText(sceneObjects(tree, zero)))
  };

  public func writeSceneFileHelper(file : Symbol, seed : Nat, size : Nat) {
    let a = R.generateRandomInput(seed, size);
    let t = fromArray(a);
    writeSceneFile(file, t!)
  };

  #[test]
  public func testWriteSceneFile() {
    let a = R.generateRandomInput(10, 10);
    let t = fromArray(a);
    writeSceneFile(`testWriteSceneFile, t!)
  };

  #[listing]
  public func sceneObjects<X>(tree : Pointer<SeqTree<X>>, origin : Vec3) : SceneObjects {
    let g = geom2d(tree);
    let label_ = (debug_show tree);
    let position = {y = g.height * 1.618; x = origin.x; z = origin.z};
    var objs = [];
    let (textFields, pointerFields) = 
      switch (@ tree) {
        case (#empty) { ("#empty", []) };
        case (#element(e)) { ("symbol="#(debug_show e.symbol)#"\nelement="#(debug_show e.element), []) };
        case (#binary(b)) { 
          objs #= [
            #pointer ( {from=label_# ":left"; to=(debug_show b.left)}),
            #pointer ( {from=label_# ":right"; to=(debug_show b.right)})
          ];
          assert (g.width == (g.widthLeft + g.widthRight));
          objs #= sceneObjects(b.left, {origin with x=origin.x - (g.widthRight * 0.5)});
          objs #= sceneObjects(b.right, {x=origin.x + (g.widthLeft * 0.5); y=origin.y; z=origin.z});
          (debug_show (#binary(b.symbol)), ["left", "right"]) 
        };
      };
    [#box({label_; position; textFields; pointerFields})] # objs
  };

  #[test]
  public func testSceneObjects() {
    let a = R.generateRandomInput(10, 10);
    let t = fromArray(a);
    let objs = sceneObjects(t!, zero);
    assert (objs.size() == 37);
    // prim "print" (objs[36]);
    let last = objs[36];
    switch last {
      case (#box(b)) {
        assert b.label_ == "10-element";
        // assert b.position.x == 1.5;
      };
      case _ { assert false };
    }
   };

  #[listing]
  public func geom2d<X>(tree : Pointer<SeqTree<X>>) : Geom2D {
    let oneUnit = { height=1; width=1; widthLeft=0.5; widthRight=0.5};
    switch (@ tree) {
      case (#empty) { oneUnit };
      case (#element(e)) { oneUnit };
      case (#binary(b)) {
        let ml = geom2d(b.left);
        let mr = geom2d(b.right);
        { 
          height = max(ml.height, mr.height) + 1; 
          widthLeft = ml.width;
          widthRight = mr.width;
          width = ml.width + mr.width;
        }
      };
    }
  };

  #[test]
  public func testGeom2d<X>(tree : Pointer<SeqTree<X>>) : Geom2D {
    let a = R.generateRandomInput(10, 10);
    let t = fromArray(a);
    let g = geom2d(t!);
    // prim "print" g;
    assert (g == 
      { height = 6;
        width = 10;
        widthLeft = 8;
        widthRight = 2 });
  };

  }; 

  public module Tests {

    #[test]
    func testFromIntoArray() {
      assert intoArray(fromArray([])) == [];
      assert intoArray(fromArray([(0,0)])) == [(0,0)];
      assert intoArray(fromArray([(0,0), (1,1)])) == [(0,0), (1,1)];
      let input = R.generateRandomInput(10, 10);
      let tree = fromArray(input);
      assert intoArray(tree) == input
    };

    #[test]
    func testSize() {
      let input = R.generateRandomInput(10, 10);
      let tree = fromArray(input);
      assert Index.size(tree) == 10;
    };

