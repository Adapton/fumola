import List "List";
import LazyList "LazyList";
import R "randomInput";

module { 
    
  #[listing(30)]
  public type LevelTree<X> = {
    #empty;
    #element : Element<X>;
    #binary : Binary<X>
  };

  #[listing]
  public type LevelTree_<X> = Pointer<LevelTree<X>>;

  #[listing(30)]
  public type Binary<X> = {
    symbol : Symbol;
    level : Nat;
    left : LevelTree_<X>;
    right : LevelTree_<X>
  };

  #[listing(23)]
  public type Element<X> = {
    element : X;
    symbol : Symbol
  };

  #[listing]
  public func reduceUp<X,Y>(
        t : LevelTree<X>, 
        empty : Y,
        element : (Symbol, X) -> Y,
        binary : (Symbol, Y, Y) -> Y) : Y 
  {
    switch t {
      case (#empty) empty;
      case (#element(e)) element(e.symbol, e.element);
      case (#binary(b)) {
        force (b.symbol := thunk {
          binary(b.symbol,
            reduceUp(@(b.left),  empty, element, binary), 
            reduceUp(@(b.right), empty, element, binary)
          )
        })
      };
    }
  };

