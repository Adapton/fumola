{
  "name": "Fumola Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#d4d4d4"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#6A9955",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#CE9178"
      }
    },
    {
      "scope": "keyword.control.fumola",
      "settings": {
        "foreground": "#569CD6",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "meta.decorator.listing.fumola",
      "settings": {
        "foreground": "#C586C0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "meta.decorator.test.fumola",
      "settings": {
        "foreground": "#b0ccb0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Fumola Symbol (Quoted Identifier)",
      "scope": "entity.name.symbol.fumola",
      "settings": {
        "foreground": "#a086a5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Fumola Variant Tag",
      "scope": "entity.name.tag.variant.fumola",
      "settings": {
        "foreground": "#a586a0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "punctuation.terminator",
      "settings": {
        "foreground": "#9999dd"
      }
    }
  ]
}