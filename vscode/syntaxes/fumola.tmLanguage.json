{
  "scopeName": "source.fumola",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#decorators"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#variantTags"
    },
    {
      "include": "#symbols"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fumola",
          "match": "\\b(module|let|return|import|type|public|force|func|thunk|switch|case|prim|if|else|var|for|in|with|within|do|assert|goto|space|time|debug_show)\\b"
        },
        {
          "name": "keyword.operator.assignment.fumola",
          "match": "(:=|\\+=|#=|-=|\\*=|/=)"
        },
        {
          "name": "keyword.operator.logical.fumola",
          "match": "(==|<=|>=|<|>|\\b(not|or|and)\\b)"
        },
        {
          "name": "keyword.operator.definition.fumola",
          "match": "="
        },
        {
          "name": "keyword.operator.sequence.fumola",
          "match": ";"
        },
        {
          "name": "keyword.operator.get.fumola",
          "match": "@"
        }
      ]
    },
    "variantTags": {
      "patterns": [
        {
          "name": "entity.name.tag.variant.fumola",
          "match": "#[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "entity.name.symbol.fumola",
          "match": "`[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "entity.builtin.fumola",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "entity.builtin.null",
          "match": "null"
        },
        {
          "name": "entity.builtin.true",
          "match": "true"
        },
        {
          "name": "entity.builtin.false",
          "match": "false"
        },
        {
          "name": "entity.builtin.option",
          "match": "\\?"
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "meta.decorator.listing.fumola",
          "match": "#\\[listing[^\\]]*\\]"
        },
        {
          "name": "meta.decorator.test.fumola",
          "match": "#\\[test[^\\]]*\\]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.fumola",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fumola",
          "begin": "\"",
          "end": "\""
        }
      ]
    }
  }
}